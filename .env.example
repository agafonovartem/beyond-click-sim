# Copy to .env (git-ignored) and fill in what you need.

# OpenAI API key — required only for `--client openai`.
OPENAI_API_KEY=

# Optional: point `--client vllm_local` at a non-default vLLM endpoint.
# Default: http://127.0.0.1:8000/v1
# BEYOND_CLICK_SIM_VLLM_LOCAL_BASE_URL=http://127.0.0.1:8000/v1
